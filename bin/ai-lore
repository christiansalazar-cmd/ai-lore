#!/usr/bin/env bash
# ai-lore â€” install shared AI assets (skills, MCPs, rules) into the current project.
# Target editor: Cursor (writes into <project>/.cursor/). See README for other editors.

set -euo pipefail

# --- Resolve the real repo location, following symlinks (install.sh may symlink us) ---
_resolve_home() {
  local source="${BASH_SOURCE[0]}" dir
  while [ -L "$source" ]; do
    dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
  # bin/ai-lore -> repo root is the parent of bin/
  dirname "$dir"
}

AI_LORE_HOME="${AI_LORE_HOME:-$(_resolve_home)}"
export AI_LORE_HOME

# shellcheck source=/dev/null
source "${AI_LORE_HOME}/lib/common.sh"

MCP_MERGE="${AI_LORE_HOME}/lib/mcp_merge.py"
FORCE=0

# --- Catalog discovery -------------------------------------------------------

# Print "label<TAB>absdir" for each skill (a dir containing SKILL.md).
discover_skills() {
  local skills_root="${AI_LORE_HOME}/skills" skill_md dir rel
  [[ -d "$skills_root" ]] || return 0
  while IFS= read -r skill_md; do
    dir="$(dirname "$skill_md")"
    rel="${dir#"$skills_root"/}"
    printf '%s\t%s\n' "$rel" "$dir"
  done < <(find "$skills_root" -type f -name SKILL.md | sort)
}

# Print "label<TAB>absdir" for each MCP template dir (contains mcp.template.json).
discover_mcps() {
  local mcp_root="${AI_LORE_HOME}/mcps" tmpl dir name
  [[ -d "$mcp_root" ]] || return 0
  while IFS= read -r tmpl; do
    dir="$(dirname "$tmpl")"
    name="$(basename "$dir")"
    printf '%s\t%s\n' "$name" "$dir"
  done < <(find "$mcp_root" -type f -name 'mcp.template.json' | sort)
}

# Print "label<TAB>absfile" for each rule (*.mdc under rules/).
discover_rules() {
  local rules_root="${AI_LORE_HOME}/rules" f name
  [[ -d "$rules_root" ]] || return 0
  while IFS= read -r f; do
    name="$(basename "$f")"
    printf '%s\t%s\n' "$name" "$f"
  done < <(find "$rules_root" -type f -name '*.mdc' | sort)
}

# --- Guards ------------------------------------------------------------------

is_inside_home() {
  local target abs_home
  target="$(cd "$1" >/dev/null 2>&1 && pwd)"
  abs_home="$(cd "$AI_LORE_HOME" >/dev/null 2>&1 && pwd)"
  [[ "$target" == "$abs_home" || "$target" == "$abs_home"/* ]]
}

# --- Install actions ---------------------------------------------------------

copy_dir() {
  # copy_dir SRC DEST
  local src="$1" dest="$2"
  if [[ -e "$dest" && "$FORCE" -ne 1 ]]; then
    if ! ui_confirm "Overwrite existing $(basename "$dest")?"; then
      echo "  skipped: $dest"
      return 0
    fi
  fi
  rm -rf "$dest"
  mkdir -p "$(dirname "$dest")"
  cp -R "$src" "$dest"
  echo "  installed: $dest"
}

install_skills() {
  local target="$1"
  local -a labels=() dirs=()
  local line
  while IFS=$'\t' read -r label dir; do
    [[ -z "$label" ]] && continue
    labels+=("$label")
    dirs+=("$dir")
  done < <(discover_skills)

  if [[ ${#labels[@]} -eq 0 ]]; then
    echo "No skills found in ${AI_LORE_HOME}/skills."
    return 0
  fi

  local chosen
  chosen="$(choose_multi "Select skills to install" "${labels[@]}")"
  [[ -z "$chosen" ]] && { echo "No skills selected."; return 0; }

  local sel i leaf
  while IFS= read -r sel; do
    [[ -z "$sel" ]] && continue
    for i in "${!labels[@]}"; do
      if [[ "${labels[$i]}" == "$sel" ]]; then
        leaf="$(basename "${dirs[$i]}")"
        copy_dir "${dirs[$i]}" "${target}/.cursor/skills/${leaf}"
        break
      fi
    done
  done <<<"$chosen"
}

install_rules() {
  local target="$1"
  local -a labels=() files=()
  while IFS=$'\t' read -r label file; do
    [[ -z "$label" ]] && continue
    labels+=("$label")
    files+=("$file")
  done < <(discover_rules)

  if [[ ${#labels[@]} -eq 0 ]]; then
    echo "No rules found in ${AI_LORE_HOME}/rules."
    return 0
  fi

  local chosen
  chosen="$(choose_multi "Select rules to install" "${labels[@]}")"
  [[ -z "$chosen" ]] && { echo "No rules selected."; return 0; }

  mkdir -p "${target}/.cursor/rules"
  local sel i dest
  while IFS= read -r sel; do
    [[ -z "$sel" ]] && continue
    for i in "${!labels[@]}"; do
      if [[ "${labels[$i]}" == "$sel" ]]; then
        dest="${target}/.cursor/rules/${labels[$i]}"
        if [[ -e "$dest" && "$FORCE" -ne 1 ]]; then
          ui_confirm "Overwrite existing rule ${labels[$i]}?" || { echo "  skipped: $dest"; break; }
        fi
        cp "${files[$i]}" "$dest"
        echo "  installed: $dest"
        break
      fi
    done
  done <<<"$chosen"
}

install_mcps() {
  local target="$1"
  local mcp_json="${target}/.cursor/mcp.json"
  local -a labels=() dirs=()
  while IFS=$'\t' read -r label dir; do
    [[ -z "$label" ]] && continue
    labels+=("$label")
    dirs+=("$dir")
  done < <(discover_mcps)

  if [[ ${#labels[@]} -eq 0 ]]; then
    echo "No MCP templates found in ${AI_LORE_HOME}/mcps."
    return 0
  fi

  local chosen
  chosen="$(choose_multi "Select MCP servers to install" "${labels[@]}")"
  [[ -z "$chosen" ]] && { echo "No MCP servers selected."; return 0; }

  mkdir -p "${target}/.cursor"
  local sel i tmpl
  while IFS= read -r sel; do
    [[ -z "$sel" ]] && continue
    for i in "${!labels[@]}"; do
      if [[ "${labels[$i]}" == "$sel" ]]; then
        tmpl="${dirs[$i]}/mcp.template.json"
        python3 "$MCP_MERGE" merge "$mcp_json" "$tmpl"
        prompt_keys_for_template "$mcp_json" "$tmpl" "${labels[$i]}"
        break
      fi
    done
  done <<<"$chosen"

  # MCP config may hold secrets; keep it out of git.
  ensure_gitignore_line "${target}/.gitignore" ".cursor/mcp.json"
  echo "  note: added .cursor/mcp.json to ${target}/.gitignore (contains keys)"
}

prompt_keys_for_template() {
  local mcp_json="$1" tmpl="$2" label="${3:-MCP}"
  local server var any=0
  while read -r server var; do
    [[ -z "$server" || -z "$var" ]] && continue
    any=1
    break
  done < <(python3 "$MCP_MERGE" list-empty-env "$mcp_json" "$tmpl")
  if [[ "$any" -eq 0 ]]; then
    echo "  ${label}: no key needed - ready to go."
    return 0
  fi
  while read -r server var; do
    [[ -z "$server" || -z "$var" ]] && continue
    echo "  MCP '${server}' needs ${var}."
    if ui_confirm "    Enter a value for ${var} now?"; then
      local secret=""
      set +o history 2>/dev/null || true
      secret="$(read_secret_masked "    ${var} (hidden): ")"
      set -o history 2>/dev/null || true
      if [[ -n "$secret" ]]; then
        printf '%s' "$secret" | python3 "$MCP_MERGE" set-env "$mcp_json" "$server" "$var"
        echo "    set ${var} for ${server}."
      else
        echo "    left ${var} empty; fill it in later in .cursor/mcp.json."
      fi
      unset secret 2>/dev/null || true
    else
      echo "    left ${var} empty; fill it in later in .cursor/mcp.json."
    fi
  done < <(python3 "$MCP_MERGE" list-empty-env "$mcp_json" "$tmpl")
}

# --- Subcommands -------------------------------------------------------------

cmd_list() {
  ui_header "Skills"
  discover_skills | awk -F '\t' '{print "  - " $1}'
  ui_header "MCP servers"
  discover_mcps | awk -F '\t' '{print "  - " $1}'
  ui_header "Rules"
  discover_rules | awk -F '\t' '{print "  - " $1}'
}

cmd_setup() {
  local target="$PWD"
  if is_inside_home "$target"; then
    echo "Refusing to run inside the ai-lore source repo." >&2
    echo "cd into one of your projects first, then run: ai-lore setup" >&2
    return 1
  fi

  ui_header "ai-lore setup"
  echo "Source : ${AI_LORE_HOME}"
  echo "Project: ${target}"
  echo "Targets: ${target}/.cursor/{skills,mcp.json,rules}"
  echo ""

  while true; do
    local action
    action="$(choose_one "What do you want to install into this project?" \
      "Skills" "MCP servers" "Rules" "Done")"
    case "$action" in
      Skills) install_skills "$target" ;;
      "MCP servers") install_mcps "$target" ;;
      Rules) install_rules "$target" ;;
      Done | "") break ;;
    esac
  done

  echo ""
  echo "Done. Reload Cursor (or the MCP panel) to pick up changes in ${target}/.cursor/."
}

usage() {
  cat <<EOF
ai-lore â€” install shared AI assets into the current project (Cursor).

Usage:
  ai-lore setup [--force]   Interactive install into \$PWD/.cursor (default)
  ai-lore list              Show available skills, MCP servers, and rules
  ai-lore --help            Show this help

Notes:
  - Run 'ai-lore setup' from inside one of your projects (not the ai-lore repo).
  - Files are COPIED, so projects keep working if ai-lore moves or updates.
  - MCP API keys go into .cursor/mcp.json and are gitignored automatically.

AI_LORE_HOME=${AI_LORE_HOME}
EOF
}

main() {
  local cmd="setup"
  if [[ $# -gt 0 ]]; then
    case "$1" in
      setup | list) cmd="$1"; shift ;;
      -h | --help | help) usage; return 0 ;;
      --force) cmd="setup" ;;
      *) echo "Unknown command: $1" >&2; usage; return 2 ;;
    esac
  fi
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --force) FORCE=1 ;;
      -h | --help) usage; return 0 ;;
      *) echo "Unknown option: $1" >&2; return 2 ;;
    esac
    shift
  done

  case "$cmd" in
    setup) cmd_setup ;;
    list) cmd_list ;;
  esac
}

main "$@"
