{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "AI Lore: setup wizard",
      "type": "shell",
      "command": "bash launcher-setup/setup-wizard.sh",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "${env:HOME}/.local/bin:${env:PATH}"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "close": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "AI Lore: setup wizard (rerun)",
      "type": "shell",
      "command": "bash launcher-setup/setup-wizard.sh",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "${env:HOME}/.local/bin:${env:PATH}"
        }
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true,
        "close": false
      }
    }
  ]
}
