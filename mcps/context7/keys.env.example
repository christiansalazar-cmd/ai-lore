# context7 works WITHOUT an API key. No key is required to install or use it.
#
# OPTIONAL: a key only raises rate limits. If you want one, get it from
# https://context7.com and add it to <project>/.cursor/mcp.json under the
# context7 server, e.g.:
#
#   "context7": {
#     "command": "npx",
#     "args": ["-y", "@upstash/context7-mcp"],
#     "env": { "CONTEXT7_API_KEY": "your-key" }
#   }
#
# CONTEXT7_API_KEY=
